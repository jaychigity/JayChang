# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager Container ID (e.g., GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_ID=

# Google Ads Account ID (e.g., AW-XXXXXXXXXX)
# Used to load the Google Ads gtag config
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads Conversion ID (e.g., AW-XXXXXXXXXX/XXXXXXXXXXXX)
# Used when firing conversion events on form submissions
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# Meta (Facebook) Pixel ID (e.g., 123456789012345)
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag Partner ID (e.g., 1234567)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# HubSpot Portal ID (e.g., 12345678)
# Loads the HubSpot tracking script for CRM attribution
NEXT_PUBLIC_HUBSPOT_ID=

# Email (Nodemailer) — used by /api/lead
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=
